# ══════════════════════════════════════════════════════════════
#  FITMART — Environment Configuration
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git
# ══════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./fitmart.db

# PostgreSQL (production):
# DATABASE_URL=postgresql://fitmart_user:password@localhost:5432/fitmart

# MySQL (alternative):
# DATABASE_URL=mysql+mysqlconnector://fitmart_user:password@localhost/fitmart

# ── Security ────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=fitmart-dev-secret-change-in-production-2025
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── AI Integration ──────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-AQ.Ab8RN6IC--Gfld-rMeyyHxkzafe0aZyQ_fzX_1WRINT2tNkOaA

# ── Email Service ───────────────────────────────────────────
EMAIL_PROVIDER=smtp
# Options: smtp | sendgrid | resend

# SMTP (Gmail/Mailgun/etc)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@fitmart.pk
FROM_NAME=FitMart

# SendGrid (alternative)
# SENDGRID_API_KEY=SG.your-key-here

# Resend (alternative)
# RESEND_API_KEY=re_your-key-here

# ── Frontend URL (for email links) ──────────────────────────
FRONTEND_URL=http://localhost:5500

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
